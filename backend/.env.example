PORT=5000

# Local MongoDB (only if you installed MongoDB on your PC):
# MONGODB_URI=mongodb://127.0.0.1:27017/crm

# MongoDB Atlas (paste from Atlas → Connect → Drivers → Node.js):
# Copy this file to .env and replace USERNAME, PASSWORD, and your real cluster host (not xxxxx)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.YOUR_CLUSTER_ID.mongodb.net/crm?retryWrites=true&w=majority
